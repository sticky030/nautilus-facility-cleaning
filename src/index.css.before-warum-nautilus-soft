@import "tailwindcss";

:root {
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
    "Segoe UI", sans-serif;
  line-height: 1.5;
  font-weight: 400;
  color: #6f6559;
  background: #f7f4ee;
  font-synthesis: none;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-width: 320px;
  background: #f7f4ee;
  color: #6f6559;
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input,
select,
textarea {
  font: inherit;
}

/* Global reveal system */
.reveal {
  opacity: 0;
  transform: translate3d(0, 28px, 0);
  transition:
    opacity 0.72s cubic-bezier(0.22, 1, 0.36, 1),
    transform 0.72s cubic-bezier(0.22, 1, 0.36, 1);
  will-change: opacity, transform;
}

.reveal.is-visible {
  opacity: 1;
  transform: translate3d(0, 0, 0);
}

.reveal-fast {
  transition-duration: 0.5s;
}

.reveal-slow {
  transition-duration: 0.9s;
}

.delay-1 {
  transition-delay: 0.08s;
}

.delay-2 {
  transition-delay: 0.16s;
}

.delay-3 {
  transition-delay: 0.24s;
}

.delay-4 {
  transition-delay: 0.32s;
}

/* Process stage sequential glow */
.process-stage.is-sequenced .process-card {
  animation: processCardPulse 0.9s cubic-bezier(0.22, 1, 0.36, 1) 1 both;
}

.process-stage.is-sequenced .process-card:nth-of-type(1) {
  animation-delay: 0.10s;
}
.process-stage.is-sequenced .process-card:nth-of-type(2) {
  animation-delay: 0.32s;
}
.process-stage.is-sequenced .process-card:nth-of-type(3) {
  animation-delay: 1.26s;
}
.process-stage.is-sequenced .process-card:nth-of-type(4) {
  animation-delay: 0.76s;
}

.process-stage.is-sequenced .process-card .process-ring {
  animation: processRingPulse 0.9s cubic-bezier(0.22, 1, 0.36, 1) 1 both;
}

.process-stage.is-sequenced .process-card:nth-of-type(1) .process-ring {
  animation-delay: 0.10s;
}
.process-stage.is-sequenced .process-card:nth-of-type(2) .process-ring {
  animation-delay: 0.32s;
}
.process-stage.is-sequenced .process-card:nth-of-type(3) .process-ring {
  animation-delay: 1.26s;
}
.process-stage.is-sequenced .process-card:nth-of-type(4) .process-ring {
  animation-delay: 0.76s;
}

.process-stage.is-sequenced .process-card .process-glow {
  animation: processGlowPulse 0.9s cubic-bezier(0.22, 1, 0.36, 1) 1 both;
}

.process-stage.is-sequenced .process-card:nth-of-type(1) .process-glow {
  animation-delay: 0.10s;
}
.process-stage.is-sequenced .process-card:nth-of-type(2) .process-glow {
  animation-delay: 0.32s;
}
.process-stage.is-sequenced .process-card:nth-of-type(3) .process-glow {
  animation-delay: 1.26s;
}
.process-stage.is-sequenced .process-card:nth-of-type(4) .process-glow {
  animation-delay: 0.76s;
}

@keyframes processCardPulse {
  0% {
    transform: translate3d(0, 0, 0);
    box-shadow: 0 14px 34px rgba(183,155,108,0.08);
  }
  35% {
    transform: translate3d(0, -4px, 0);
    box-shadow: 0 28px 60px rgba(183,155,108,0.18);
  }
  100% {
    transform: translate3d(0, 0, 0);
    box-shadow: 0 14px 34px rgba(183,155,108,0.08);
  }
}

@keyframes processRingPulse {
  0% {
    opacity: 0;
  }
  35% {
    opacity: 1;
    box-shadow: inset 0 0 0 1px rgba(214,190,146,0.55);
  }
  100% {
    opacity: 0;
    box-shadow: inset 0 0 0 1px rgba(214,190,146,0);
  }
}

@keyframes processGlowPulse {
  0% {
    opacity: 0;
  }
  35% {
    opacity: 1;
  }
  100% {
    opacity: 0;
  }
}

/* Process stage sequence when fully visible */
.process-stage .process-card,
.process-stage .process-line {
  will-change: transform, opacity, box-shadow;
}

.process-stage.is-sequenced .process-card {
  animation: processCardPulse 1.95s cubic-bezier(0.22, 1, 0.36, 1) 1 both;
}

.process-stage.is-sequenced .process-card:nth-of-type(1) { animation-delay: 0.30s; }
.process-stage.is-sequenced .process-card:nth-of-type(2) { animation-delay: 0.92s; }
.process-stage.is-sequenced .process-card:nth-of-type(3) { animation-delay: 1.54s; }
.process-stage.is-sequenced .process-card:nth-of-type(4) { animation-delay: 2.16s; }

.process-stage.is-sequenced .process-card .process-ring {
  animation: processRingPulse 1.95s cubic-bezier(0.22, 1, 0.36, 1) 1 both;
}

.process-stage.is-sequenced .process-card:nth-of-type(1) .process-ring { animation-delay: 0.30s; }
.process-stage.is-sequenced .process-card:nth-of-type(2) .process-ring { animation-delay: 0.92s; }
.process-stage.is-sequenced .process-card:nth-of-type(3) .process-ring { animation-delay: 1.54s; }
.process-stage.is-sequenced .process-card:nth-of-type(4) .process-ring { animation-delay: 2.16s; }

.process-stage.is-sequenced .process-card .process-glow {
  animation: processGlowPulse 1.95s cubic-bezier(0.22, 1, 0.36, 1) 1 both;
}

.process-stage.is-sequenced .process-card:nth-of-type(1) .process-glow { animation-delay: 0.30s; }
.process-stage.is-sequenced .process-card:nth-of-type(2) .process-glow { animation-delay: 0.92s; }
.process-stage.is-sequenced .process-card:nth-of-type(3) .process-glow { animation-delay: 1.54s; }
.process-stage.is-sequenced .process-card:nth-of-type(4) .process-glow { animation-delay: 2.16s; }

.process-stage.is-sequenced .line-1 {
  animation: processLinePulse 1.6s cubic-bezier(0.22, 1, 0.36, 1) 1 both;
  animation-delay: 0.64s;
}

.process-stage.is-sequenced .line-2 {
  animation: processLinePulse 1.6s cubic-bezier(0.22, 1, 0.36, 1) 1 both;
  animation-delay: 1.26s;
}

.process-stage.is-sequenced .line-3 {
  animation: processLinePulse 1.6s cubic-bezier(0.22, 1, 0.36, 1) 1 both;
  animation-delay: 1.88s;
}

@keyframes processCardPulse {
  0% {
    transform: translate3d(0, 0, 0);
    box-shadow: 0 14px 34px rgba(183,155,108,0.08);
  }
  35% {
    transform: translate3d(0, -4px, 0);
    box-shadow: 0 28px 60px rgba(183,155,108,0.18);
  }
  100% {
    transform: translate3d(0, 0, 0);
    box-shadow: 0 14px 34px rgba(183,155,108,0.08);
  }
}

@keyframes processRingPulse {
  0% {
    opacity: 0;
    box-shadow: inset 0 0 0 1px rgba(214,190,146,0);
  }
  35% {
    opacity: 1;
    box-shadow: inset 0 0 0 1px rgba(214,190,146,0.55);
  }
  100% {
    opacity: 0;
    box-shadow: inset 0 0 0 1px rgba(214,190,146,0);
  }
}

@keyframes processGlowPulse {
  0% { opacity: 0; }
  35% { opacity: 1; }
  100% { opacity: 0; }
}

@keyframes processLinePulse {
  0% {
    opacity: 0.18;
    filter: blur(0.4px);
  }
  35% {
    opacity: 1;
    filter: blur(0.2px);
  }
  100% {
    opacity: 0.28;
    filter: blur(0.4px);
  }
}
